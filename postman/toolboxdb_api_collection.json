        "type": "text/javascript",
        "exec": [
          "pm.test('Response carries global X-Correlation-ID metadata', function () {",
          "    if (pm.response.code !== 404) {",
          "        pm.expect(pm.response.headers.has('X-Correlation-ID')).to.be.true;",
          "    }",
          "});"
        ]
