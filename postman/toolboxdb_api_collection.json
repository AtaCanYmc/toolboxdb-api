                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"ESP32-WROOM-32\",\n  \"quantity\": 15,\n  \"category_id\": 1,\n  \"datasheet_url\": \"https://example.com/datasheet.pdf\",\n  \"technical_specs\": {\n    \"voltage\": \"3.3V\",\n    \"wifi\": \"802.11 b/g/n\"\n  }\n}"
