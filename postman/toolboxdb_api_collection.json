                {
                    "name": "7. Delete Entire Invoice (Admin)",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{base_url}}/api/v1/invoices/f1c50e93-2710-449e-b9b5-6804a9af35b8",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
