                {
                    "name": "Delete Component (Admin)",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{base_url}}/api/v1/components/a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "components",
                                "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Invoices",
            "description": "Invoice management. Upload (Admin/User), Approve/Edit/Delete (Admin Only).",
            "auth": {
                "type": "bearer",
                "bearer": [
                    {
                        "key": "token",
                        "value": "{{auth_token}}",
                        "type": "string"
                    }
                ]
            },
            "item": [
                {
                    "name": "1. Upload PDF Invoice (Admin & User)",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{base_url}}/api/v1/invoices/upload",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "invoices",
                                "upload"
                            ]
                        },
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "file",
                                    "type": "file",
                                    "src": []
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "2. List All Invoices",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/api/v1/invoices/",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "invoices",
                                ""
                            ]
                        }
                    }
                },
                {
                    "name": "3. Get Invoice Detail",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/api/v1/invoices/f1c50e93-2710-449e-b9b5-6804a9af35b8",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "invoices",
                                "f1c50e93-2710-449e-b9b5-6804a9af35b8"
                            ]
                        }
                    }
                },
                {
                    "name": "4. Fix/Edit Extracted Item (Admin)",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/invoices/items/c810d7a6-b519-482a-912a-048b2611a5b8",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "invoices",
                                "items",
                                "c810d7a6-b519-482a-912a-048b2611a5b8"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"clean_name\": \"Corrected Component Name\",\n  \"quantity\": 100,\n  \"category_name\": \"Resistors\"\n}"
                        }
                    }
                },
                {
                    "name": "5. Delete Extracted Item (Admin)",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{base_url}}/api/v1/invoices/items/c810d7a6-b519-482a-912a-048b2611a5b8",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "invoices",
                                "items",
                                "c810d7a6-b519-482a-912a-048b2611a5b8"
                            ]
                        }
                    }
                },
                {
                    "name": "6. Approve & Add to Inventory (Admin)",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{base_url}}/api/v1/invoices/f1c50e93-2710-449e-b9b5-6804a9af35b8/approve",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "invoices",
                                "f1c50e93-2710-449e-b9b5-6804a9af35b8",
                                "approve"
