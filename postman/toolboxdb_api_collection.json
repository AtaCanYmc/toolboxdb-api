    {
      "name": "Invoices & AI Flow",
      "item": [
        {
          "name": "Upload PDF Invoice",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('active_invoice_id', jsonData.id);",
                  "    if(jsonData.items && jsonData.items.length > 0) {",
                  "        pm.collectionVariables.set('active_item_id', jsonData.items[0].id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Correlation-ID",
                "value": "postman-tracing-uuid-123",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "description": "Select sample pdf here."
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/invoices/upload",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "invoices",
                "upload"
              ]
            },
            "description": "Extracts text, parses via LLM, maps to draft staging tables. Saves generated UUIDs automatically."
          },
          "response": []
        },
        {
          "name": "Get Invoice Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/invoices/{{active_invoice_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "invoices",
                "{{active_invoice_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Approve Invoice Staging Items",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/invoices/{{active_invoice_id}}/approve",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "invoices",
                "{{active_invoice_id}}",
                "approve"
              ]
            },
            "description": "Processes staging items into final core inventory components."
          },
          "response": []
        }
      ]
