              "raw": "{{base_url}}/api/v1/category",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "category"
              ]
            },
            "description": "Creates a new category and invalidates 'categories:all' cache. Saves generated ID automatically."
          },
          "response": []
