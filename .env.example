# Environment variables for FastAPI application

# Database configuration (supported values: postgresql, supabase)
DATABASE_TYPE=supabase

# Database connection settings (for PostgreSQL, adjust as needed)
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Supabase settings (only needed if DATABASE_TYPE is set to supabase)
SUPABASE_DATABASE_URL=postgresql://postgres

# SQLAlchemy connection pool settings
POOL_PRE_PING=True
POOL_SIZE=5
MAX_OVERFLOW=5
POOL_RECYCLE=3600

# FastAPI server settings
APP_TITLE='FastAPI Application'
APP_VERSION=1.0.0
HOST=localhost
PORT=8000
DEBUG=True
RELOAD=True

# Options: OPENAI, GROQ, OLLAMA
LLM_PROVIDER=GROQ

# API keys for LLM providers (only needed for the selected provider)
OPENAI_API_KEY=sk-proj-...
GROQ_API_KEY=gsk_...
OLLAMA_MODEL=llama3.1

# Redis configuration
REDIS_URL=redis://localhost:6379/0